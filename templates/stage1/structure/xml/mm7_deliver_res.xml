<DeliverRsp xmlns="http://www.3gpp.org/ftp/Specs/archive/23_series/23.140/schema/REL-6-MM7-1-4">
  <!-- 1. required -->
  <MM7Version>{{required_mm7_version}}</MM7Version>

  <!-- 2. required container -->
  <Status>
    <StatusCode>{{required_positive_integer}}</StatusCode>
    <!-- required by XSD -->
    <StatusText>{{required_status_text_by_xsd}}</StatusText>
    <!-- optional -->
    <Details>{{optional_details}}</Details>
  </Status>

  <!-- 3. optional -->
  <ServiceCode>{{optional_service_code}}</ServiceCode>
</DeliverRsp>
